<section class="bg-[#D00000] py-12">
  <div class="container mx-auto px-4 text-center">
    <h3 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-[#1a1a1a]">
      {{ section.settings.text }}
    </h3>
  </div>
</section>

{% schema %}
{
  "name": "Mission Banner",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "\"The only easy day was yesterday.\""
    }
  ],
  "presets": [
    {
      "name": "Mission Banner"
    }
  ]
}
{% endschema %}
