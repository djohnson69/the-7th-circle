<section class="relative h-[85vh] w-full overflow-hidden bg-black">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    {% if section.settings.hero_image != blank %}
      <img 
        src="{{ section.settings.hero_image | img_url: 'master' }}" 
        alt="{{ section.settings.heading }}" 
        class="h-full w-full object-cover opacity-60"
      />
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'h-full w-full object-cover opacity-60' }}
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-t from-[#121212] via-[#121212]/20 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#121212] via-transparent to-transparent opacity-80"></div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto flex h-full flex-col justify-center px-4">
    <div class="max-w-3xl animate-fade-up">
      <div class="mb-4 inline-block border-l-4 border-[#D00000] pl-4">
        <span class="font-display text-lg font-bold uppercase tracking-[0.2em] text-[#D00000]">
          {{ section.settings.subheading }}
        </span>
      </div>
      <h1 class="mb-6 font-display text-6xl md:text-8xl font-bold uppercase leading-[0.9] tracking-tighter text-white">
        {{ section.settings.heading }}
      </h1>
      <p class="mb-8 max-w-xl text-lg text-gray-300 font-light leading-relaxed">
        {{ section.settings.text }}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="{{ section.settings.button_link_1 }}" class="inline-flex items-center justify-center h-14 min-w-[180px] bg-[#D00000] px-8 text-lg font-bold uppercase tracking-widest text-[#1a1a1a] hover:bg-[#D00000]/90 transition-colors">
          {{ section.settings.button_label_1 }}
        </a>
        {% if section.settings.button_label_2 != blank %}
          <a href="{{ section.settings.button_link_2 }}" class="inline-flex items-center justify-center h-14 min-w-[180px] border-2 border-white bg-transparent px-8 text-lg font-bold uppercase tracking-widest text-white hover:bg-white hover:text-black transition-colors">
            {{ section.settings.button_label_2 }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Est. 2025"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Unapologetically <br> Strong"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Gear built for the few who refuse to quit."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 Label",
      "default": "Shop Mens"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 Label",
      "default": "Shop Womens"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
