<section class="grid grid-cols-1 md:grid-cols-2 min-h-[600px]">
  <div class="relative flex items-center justify-center overflow-hidden group bg-neutral-900">
     <div class="absolute inset-0 z-0">
        {% if section.settings.image_1 != blank %}
          <img src="{{ section.settings.image_1 | img_url: 'master' }}" class="h-full w-full object-cover opacity-40 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-50">
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'h-full w-full object-cover opacity-40' }}
        {% endif %}
     </div>
     <div class="relative z-10 text-center p-8">
       <h2 class="font-display text-5xl font-bold uppercase tracking-tighter text-white mb-4 drop-shadow-lg">{{ section.settings.title_1 }}</h2>
       <a href="{{ section.settings.link_1 }}" class="inline-block border-2 border-white bg-transparent text-white hover:bg-white hover:text-black uppercase font-bold tracking-widest px-8 py-4 transition-colors">
         {{ section.settings.label_1 }}
       </a>
     </div>
  </div>

  <div class="relative flex items-center justify-center overflow-hidden group bg-neutral-900">
     <div class="absolute inset-0 z-0">
        {% if section.settings.image_2 != blank %}
          <img src="{{ section.settings.image_2 | img_url: 'master' }}" class="h-full w-full object-cover opacity-40 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-50">
        {% else %}
          {{ 'collection-2' | placeholder_svg_tag: 'h-full w-full object-cover opacity-40' }}
        {% endif %}
     </div>
     <div class="relative z-10 text-center p-8">
       <h2 class="font-display text-5xl font-bold uppercase tracking-tighter text-white mb-4 drop-shadow-lg">{{ section.settings.title_2 }}</h2>
       <a href="{{ section.settings.link_2 }}" class="inline-block border-2 border-white bg-transparent text-white hover:bg-white hover:text-black uppercase font-bold tracking-widest px-8 py-4 transition-colors">
         {{ section.settings.label_2 }}
       </a>
     </div>
  </div>
</section>

{% schema %}
{
  "name": "Split Hero",
  "settings": [
    {
      "type": "header",
      "content": "Left Block"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title",
      "default": "Training"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Button Label",
      "default": "Shop Gear"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Right Block"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "Lifestyle"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Button Label",
      "default": "Shop Apparel"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Split Hero"
    }
  ]
}
{% endschema %}
