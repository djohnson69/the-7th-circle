<div class="group relative overflow-hidden rounded-none border-none bg-transparent transition-all">
  <div class="relative aspect-square overflow-hidden bg-[#1a1a1a]">
    <a href="{{ product.url }}">
      <img 
        src="{{ product.featured_image | img_url: '600x' }}" 
        alt="{{ product.title | escape }}" 
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      >
    </a>
    <div class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/10"></div>
    
    <!-- Quick Add Button -->
    <div class="absolute bottom-0 left-0 right-0 translate-y-full p-4 transition-transform duration-300 group-hover:translate-y-0">
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
        <button type="submit" class="w-full h-10 flex items-center justify-center bg-white text-black hover:bg-[#D00000] hover:text-[#1a1a1a] font-display uppercase tracking-wider font-bold transition-colors">
          Quick Add
        </button>
      </form>
    </div>
  </div>
  <div class="flex flex-col items-start gap-1 p-4 pl-0">
    <span class="text-xs font-bold uppercase tracking-widest text-gray-500">{{ product.type }}</span>
    <h3 class="font-display text-xl font-bold uppercase tracking-tight text-[#f2f2f2] group-hover:text-[#D00000] transition-colors">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <span class="font-sans text-lg font-medium text-gray-300">{{ product.price | money }}</span>
  </div>
</div>
